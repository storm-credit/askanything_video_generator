{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["api_server.py"],
      "port": 8004,
      "autoPort": false,
      "env": { "UVICORN_RELOAD": "false", "API_PORT": "8004" }
    },
    {
      "name": "frontend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/next/dist/bin/next", "dev", "--port", "3001"],
      "cwd": "frontend",
      "port": 3001,
      "autoPort": false,
      "env": { "NEXT_PUBLIC_API_URL": "http://localhost:8004" }
    }
  ]
}
