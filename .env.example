# === 필수 (Required) ===
OPENAI_API_KEY="sk-proj-YOUR_OPENAI_API_KEY_HERE"
ELEVENLABS_API_KEY="YOUR_ELEVENLABS_API_KEY_HERE"

# === 선택 (Optional - 기능별 활성화) ===
# OpenAI 모델 설정 (기본값: gpt-4o)
OPENAI_MODEL="gpt-4o"

# Tavily 팩트체크 검색 (없으면 팩트체크 건너뜀)
TAVILY_API_KEY="YOUR_TAVILY_API_KEY_HERE"

# === 비디오 엔진 (프론트엔드에서 선택 가능) ===

# Kling AI 직접 연동
KLING_ACCESS_KEY="YOUR_KLING_ACCESS_KEY_HERE"
KLING_SECRET_KEY="YOUR_KLING_SECRET_KEY_HERE"

# Google Veo 3 (Vertex AI / Gemini API)
# GOOGLE_API_KEY="YOUR_GOOGLE_API_KEY_HERE"

# === 모델 오버라이드 (기본값: 자동 체인 — Standard → Fast 폴백) ===
# 아래 설정 시 모델 체인이 비활성화되고 지정 모델만 사용합니다.
# IMAGEN_MODEL="imagen-4.0-generate-001"
# VEO_MODEL="veo-3.0-generate-001"
# GEMINI_MODEL="gemini-2.5-pro"

# ImageMagick (레거시 FFmpeg 파이프라인용, Remotion 사용 시 불필요)
# IMAGEMAGICK_BINARY="C:\Program Files\ImageMagick-7.1.1-Q16-HDRI\magick.exe"
