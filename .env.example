# === 필수 (Required) ===
OPENAI_API_KEY="sk-proj-YOUR_OPENAI_API_KEY_HERE"
ELEVENLABS_API_KEY="YOUR_ELEVENLABS_API_KEY_HERE"

# === Google AI (Gemini LLM + Imagen 이미지 + Veo 비디오) ===
# 단일 키
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"
# 멀티 키 로테이션 (쉼표 구분 — 429 시 자동 전환)
# GEMINI_API_KEYS="key1,key2,key3"

# Vertex AI 멀티 SA 모드 (RPM 분산 — 429 대폭 감소)
# 설정법:
#   1) GEMINI_BACKEND=vertex_ai 로 변경
#   2) 프로젝트 루트에 SA 키 파일 배치:
#      vertex-sa-key.json               (shortspulse — 메인)
#      vertex-sa-key-wonderdrop.json    (certain-upgrade)
#      vertex-sa-key-exploratodo.json   (exploratodo)
#      vertex-sa-key-prismtale.json     (endless-ripple)
# GEMINI_BACKEND=vertex_ai
# VERTEX_SA_ONLY=true                 # Google API Key 대신 Vertex SA만 사용
# VERTEX_SA_DIR="data/vertex_sa"      # 설정창 드래그앤드롭 SA 저장 위치
# GOOGLE_APPLICATION_CREDENTIALS=""   # 단일 SA 고정 금지. 설정창 로테이션을 사용하세요.

# === 선택 (Optional - 기능별 활성화) ===
# OpenAI 모델 설정 (기본값: gpt-4o)
OPENAI_MODEL="gpt-4o"

# Claude LLM 프로바이더 (프론트엔드에서 선택 가능)
# ANTHROPIC_API_KEY="YOUR_ANTHROPIC_API_KEY_HERE"

# Tavily 팩트체크 검색 (없으면 팩트체크 건너뜀)
TAVILY_API_KEY="YOUR_TAVILY_API_KEY_HERE"

# === 비디오 엔진 (프론트엔드에서 선택 가능) ===

# Kling AI 직접 연동
KLING_ACCESS_KEY="YOUR_KLING_ACCESS_KEY_HERE"
KLING_SECRET_KEY="YOUR_KLING_SECRET_KEY_HERE"

# === 모델 오버라이드 (기본값: 자동 체인 — Standard → Fast 폴백) ===
# 아래 설정 시 모델 체인이 비활성화되고 지정 모델만 사용합니다.
# IMAGEN_MODEL="imagen-4.0-generate-001"
# VEO_MODEL="veo-3.0-generate-001"

# === Automation / Scheduler ===
# 2:00 KST daily Day-file auto deploy. This can run paid APIs such as Veo3/Imagen.
AUTO_DEPLOY_CRON_ENABLED=false
AUTO_DEPLOY_CRON_HOUR=2
AUTO_DEPLOY_CRON_MINUTE=0
ROLLOUT_EXPANSION_CRON_ENABLED=false
ROLLOUT_EXPANSION_CRON_MINUTE=20
ROLLOUT_EXPANSION_DELAY_HOURS=24
ROLLOUT_EXPANSION_LIMIT=6
ROLLOUT_EXPANSION_MIN_VIEWS=800
ROLLOUT_EXPANSION_AVG_MULTIPLIER=1.0
AUTO_DEPLOY_MAX_PER_CHANNEL=3
# Topic planner orchestra (weekly 7-day Day files)
TOPIC_ORCHESTRA_ENABLED=true
TOPIC_ORCHESTRA_STRICT=false
# TOPIC_LLM_MODEL="gpt-5.4"
# TOPIC_LOG_DIR="assets/_topic_logs"
# GEMINI_MODEL="gemini-2.5-pro"

# External 1M+ YouTube benchmark motifs for topic planning
# Uses YouTube Data API search/videos.list and stores only videos above TOPIC_BENCHMARK_MIN_VIEWS.
TOPIC_BENCHMARK_ENABLED=true
TOPIC_BENCHMARK_AUTO_REFRESH=true
TOPIC_BENCHMARK_MIN_VIEWS=1000000
TOPIC_BENCHMARK_REFRESH_TTL_HOURS=24
TOPIC_BENCHMARK_MAX_RESULTS_PER_QUERY=25
TOPIC_BENCHMARK_PUBLISHED_AFTER_DAYS=90
TOPIC_BENCHMARK_SEARCH_ORDER=viewCount
# YOUTUBE_API_KEY_BENCHMARK="YOUR_YOUTUBE_DATA_API_KEY"
# TOPIC_BENCHMARK_SEARCH_QUERIES="en|science facts shorts;en|space facts shorts;es|curiosidades del espacio shorts;ko|우주 과학 쇼츠"
# TOPIC_BENCHMARK_CHANNEL_IDS="en|channel name|UCxxxxxxxx;es|canal externo|UCyyyyyyyy"

# === 업로드 플랫폼 (YouTube / TikTok / Instagram Reels) ===
# YouTube: Google Cloud Console → OAuth 2.0 클라이언트 ID → client_secret.json 다운로드
# YOUTUBE_CLIENT_SECRET="client_secret.json"
# YOUTUBE_REDIRECT_URI="http://localhost:8003/api/youtube/callback"

# TikTok: developers.tiktok.com → Content Posting API 앱
# TIKTOK_CLIENT_KEY="YOUR_TIKTOK_CLIENT_KEY"
# TIKTOK_CLIENT_SECRET="YOUR_TIKTOK_CLIENT_SECRET"
# TIKTOK_REDIRECT_URI="http://localhost:8003/api/tiktok/callback"

# Instagram Reels: Facebook App → Instagram Graph API
# INSTAGRAM_APP_ID="YOUR_FACEBOOK_APP_ID"
# INSTAGRAM_APP_SECRET="YOUR_FACEBOOK_APP_SECRET"
# INSTAGRAM_REDIRECT_URI="http://localhost:8003/api/instagram/callback"
# PUBLIC_SERVER_URL="https://your-server.ngrok.io"  # Instagram은 공개 URL 필요

# === 고급 설정 ===
# MAX_CONCURRENT_GENERATE=2          # 동시 생성 요청 제한
# ELEVENLABS_VOICE_ID="YOUR_VOICE"   # TTS 음성 ID (기본값: Eric)
# ELEVENLABS_SPEED=0.9               # TTS 속도 (0.7~1.2, 기본값: 0.9)
# IMAGEN_SAFETY_FILTER="BLOCK_LOW_AND_ABOVE"  # 이미지 안전 필터 수준
# CLAUDE_MODEL="claude-sonnet-4-20250514"     # Claude LLM 모델
# GOOGLE_API_KEY=""                   # GEMINI_API_KEY 대안 (Google AI Studio)

# EXCHANGE_RATE=1380                  # KRW/USD 환율 (비용 추적용, 기본값: 1380)
# BILLING_ALERT_THRESHOLD_KRW=400000  # 외부 결제 화면 총액 경고 기준
# BILLING_ALERT_CRON_ENABLED=true     # 매시간 청구 금액 기준선 확인
# BILLING_ALERT_CRON_MINUTE=5         # 매시간 몇 분에 확인할지
# BILLING_CURRENT_KRW=0               # 설정 화면 저장값이 없을 때 쓸 현재 사용금액
# BILLING_TOTAL_KRW=0                 # 설정 화면 저장값이 없을 때 쓸 총 청구금액

# === 서버 설정 ===
# API_PORT=8003                       # 백엔드 포트 (기본값: 8003)
# CORS_ORIGINS="http://localhost:3000"  # CORS 허용 오리진 (쉼표 구분)
# UVICORN_RELOAD=true                 # 개발 시 자동 리로드

# === ngrok (Instagram 등 공개 URL 필요 시) ===
# NGROK_AUTHTOKEN="YOUR_NGROK_TOKEN"
