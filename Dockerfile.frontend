# ── Frontend: Next.js 16 ──
FROM node:20-alpine AS frontend

WORKDIR /app

# Dependencies
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm install

# App code
COPY frontend/ .

# Build for production
RUN npm run build

EXPOSE 3000

ENV HOSTNAME=0.0.0.0
ENV PORT=3000

CMD ["npm", "start"]
